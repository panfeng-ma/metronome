DEFAULT_CONSUME_TOKENS=1
DEMO_USER_EMAIL=demo@example.com

# Optional: override local demo state storage. Defaults to ./data/store.json.
# BILL_SERVICE_DATA_DIR=./data

# Required for the card binding redirect. The app creates a Stripe Checkout
# Setup Mode session and sets the saved card as the customer's default payment
# method when the user returns.
# STRIPE_SECRET_KEY=sk_test_xxx

# Required to create Metronome customers and to call Metronome APIs.
# METRONOME_BEARER_TOKEN=metronome_sandbox_xxx
# Required to create a per-customer Metronome contract for prepaid commits.
# METRONOME_RATE_CARD_ID=rate_card_xxx
# Required to create prepaid recharge commits and auto-recharge threshold commits
# through Metronome.
# METRONOME_COMMIT_PRODUCT_ID=product_xxx
# Minimum USD gap between auto-recharge trigger threshold and minimum retained
# balance. The current demo default matches Metronome's observed minimum top-up
# of 1000 cents.
# MIN_AUTO_RECHARGE_TOP_UP_AMOUNT=10
# Optional: send real low-balance emails. Without this, reminders are logged.
# Low-balance reminders trigger when available balance is at or below this USD
# amount. If auto recharge is configured, its trigger threshold is used.
# LOW_BALANCE_REMINDER_THRESHOLD=2
# SMTP_HOST=smtp.qiye.aliyun.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=notice@yourdomain.com
# SMTP_PASS=email_password
# MAIL_FROM="Token Center <notice@yourdomain.com>"
